NEXT_PUBLIC_BASE_URL=http://127.0.0.1:3000

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

LASTFM_API_KEY=

# AI — v2
# Local dev: leave GROQ_API_KEY unset and run Ollama (ollama run llama3.2)
# Production: set GROQ_API_KEY from console.groq.com (free, no CC required)
GROQ_API_KEY=
# Ollama base URL (local dev only, ignored in production)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Sentry — error tracking (optional, server-side)
# Get your DSN from sentry.io → Project → Settings → Client Keys
# Set in Vercel environment variables (Production only)
NEXT_PUBLIC_SENTRY_DSN=
